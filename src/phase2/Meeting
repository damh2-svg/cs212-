package phase2;//

public class Meeting extends Event implements IMeeting {

    private int advisorId;

    private int studentId;

    private BSTSet<Integer> participantIds;

    public Meeting(int id,
                   ITimeSlot timeSlot,
                   ILocation location,
                   int advisorId,
                   int studentId) {

        super(id, timeSlot, location);

        this.advisorId = advisorId;
        this.studentId = studentId;

        participantIds = new BSTSet<>();

        participantIds.insert(advisorId);
        participantIds.insert(studentId);
    }

    @Override
    public int getAdvisorId() {
        return advisorId;
    }

    @Override
    public int getStudentId() {
        return studentId;
    }

    @Override
    public Set<Integer> getParticipantIds() {
        return participantIds;
    }
}
