package phase2;//

public class Workshop extends Event implements IWorkshop {

    private String title;

    private BSTSet<Integer> advisorIds;

    private BSTSet<Integer> studentIds;

    private BSTSet<Integer> participantIds;

    public Workshop(int id,
                    String title,
                    ITimeSlot timeSlot,
                    ILocation location) {

        super(id, timeSlot, location);

        this.title = title;

        advisorIds = new BSTSet<>();
        studentIds = new BSTSet<>();

        participantIds = new BSTSet<>();
    }

    @Override
    public String getTitle() {
        return title;
    }

    @Override
    public Set<Integer> getAdvisorIds() {
        return advisorIds;
    }

    @Override
    public Set<Integer> getStudentIds() {
        return studentIds;
    }

    @Override
    public Set<Integer> getParticipantIds() {
        return participantIds;
    }

    public boolean addAdvisor(int advisorId) {

        boolean added = advisorIds.insert(advisorId);

        if (added)
            participantIds.insert(advisorId);

        return added;
    }

    public boolean addStudent(int studentId) {

        boolean added = studentIds.insert(studentId);

        if (added)
            participantIds.insert(studentId);

        return added;
    }

    public boolean removeAdvisor(int advisorId) {

        participantIds.remove(advisorId);

        return advisorIds.remove(advisorId);
    }

    public boolean removeStudent(int studentId) {

        participantIds.remove(studentId);

        return studentIds.remove(studentId);
    }
}
