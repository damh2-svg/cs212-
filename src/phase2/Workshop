package phase2;

public class Workshop extends Event implements IWorkshop {

    private String title;
    private Set<Integer> advisorIds;
    private Set<Integer> studentIds;

    public Workshop(int id, String title, ITimeSlot timeSlot, ILocation location) {
        super(id, timeSlot, location, new BSTSet<Integer>());

        this.title = title;
        advisorIds = new BSTSet<Integer>();
        studentIds = new BSTSet<Integer>();
    }

    public Workshop(int id, String title, ITimeSlot timeSlot, ILocation location,
                    Set<Integer> advisorIds, Set<Integer> studentIds) {

        super(id, timeSlot, location, new BSTSet<Integer>());

        this.title = title;
        this.advisorIds = new BSTSet<Integer>();
        this.studentIds = new BSTSet<Integer>();

        copyAdvisorIds(advisorIds);
        copyStudentIds(studentIds);
    }

    private void copyAdvisorIds(Set<Integer> source) {
        List<Integer> keys = source.getKeys();

        if (!keys.empty()) {
            keys.findFirst();

            while (true) {
                int id = keys.retrieve();

                advisorIds.insert(id);
                participantIds.insert(id);

                if (keys.last())
                    break;

                keys.findNext();
            }
        }
    }

    private void copyStudentIds(Set<Integer> source) {
        List<Integer> keys = source.getKeys();

        if (!keys.empty()) {
            keys.findFirst();

            while (true) {
                int id = keys.retrieve();

                studentIds.insert(id);
                participantIds.insert(id);

                if (keys.last())
                    break;

                keys.findNext();
            }
        }
    }

    @Override
    public String getTitle() {
        return title;
    }

    @Override
    public Set<Integer> getAdvisorIds() {
        return advisorIds;
    }

    @Override
    public Set<Integer> getStudentIds() {
        return studentIds;
    }

    public void addAdvisor(int advisorId) {
        advisorIds.insert(advisorId);
        participantIds.insert(advisorId);
    }

    public void removeAdvisor(int advisorId) {
        advisorIds.remove(advisorId);
        participantIds.remove(advisorId);
    }

    public void addStudent(int studentId) {
        studentIds.insert(studentId);
        participantIds.insert(studentId);
    }

    public void removeStudent(int studentId) {
        studentIds.remove(studentId);
        participantIds.remove(studentId);
    }
}
